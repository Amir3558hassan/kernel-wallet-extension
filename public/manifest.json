{
  "manifest_version": 3,
  "name": "KernelWallet - Secure Multi-Chain Wallet",
  "short_name": "KernelWallet",
  "version": "1.0.0",
  "description": "Self-custodial multi-asset wallet supporting BTC, USDT, XAUt, ETH, SOL and more",
  "author": "KernelWallet Team",
  "homepage_url": "https://kernelwallet.io",
  
  "permissions": [
    "storage",
    "activeTab",
    "alarms",
    "scripting",
    "unlimitedStorage",
    "clipboardWrite",
    "offscreen"
  ],
  
  "host_permissions": [
    "https://*/*",
    "http://localhost:*/*"
  ],
  
  "action": {
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "public/icons/icon16.png",
      "32": "public/icons/icon32.png",
      "48": "public/icons/icon48.png",
      "128": "public/icons/icon128.png"
    }
  },
  
  "background": {
    "service_worker": "src/background/service-worker.js",
    "type": "module"
  },
  
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["src/content/content-script.js"],
      "run_at": "document_start",
      "all_frames": true
    }
  ],
  
  "web_accessible_resources": [
    {
      "resources": ["src/*", "assets/*", "public/*"],
      "matches": ["<all_urls>"]
    }
  ],
  
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'none'; connect-src 'self' https: http:; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; font-src 'self'; frame-src 'none';"
  },
  
  "icons": {
    "16": "public/icons/icon16.png",
    "32": "public/icons/icon32.png",
    "48": "public/icons/icon48.png",
    "128": "public/icons/icon128.png"
  }
}
